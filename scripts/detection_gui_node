#!/usr/bin/env python3
"""
ROS 2 subscriber node — displays Detection2DArray messages in a Tkinter GUI.

Parameters
----------
  topic  (string)  Topic to subscribe to  [default: "detections"]

Usage
-----
  ros2 run hailo_detector detection_gui_node
  ros2 run hailo_detector detection_gui_node --ros-args -p topic:=my_detections
"""

import queue
import sys
import threading
import tkinter as tk
from datetime import datetime, timezone
from tkinter import ttk

try:
    import rclpy
    from rclpy.node import Node
    from vision_msgs.msg import Detection2DArray
except ImportError as exc:
    raise SystemExit(f"ROS 2 import failed: {exc}\nSource your ROS 2 setup.bash first.")

# ─────────────────────────────────────────────────────────────────────────────
# Configuration
# ─────────────────────────────────────────────────────────────────────────────

MAX_LOG_ROWS = 500
POLL_MS      = 50

LOG_COLS   = ("#", "stamp", "frame_id", "detections")
LOG_WIDTHS = (55, 200, 110, 90)

DET_COLS   = ("class", "confidence", "center_x", "center_y", "size_x", "size_y")
DET_WIDTHS = (130, 100, 100, 100, 80, 80)

# ─────────────────────────────────────────────────────────────────────────────
# ROS 2 subscriber node
# ─────────────────────────────────────────────────────────────────────────────

class DetectionSubscriber(Node):
    """Thin ROS 2 node — pushes incoming messages to a queue for the GUI."""

    def __init__(self, msg_queue: queue.Queue, topic: str):
        super().__init__("detection_gui")
        self._queue = msg_queue
        self.create_subscription(Detection2DArray, topic,
                                 self._on_message, 10)
        self.get_logger().info(f"Subscribed to '{topic}'")

    def _on_message(self, msg: Detection2DArray) -> None:
        self._queue.put(msg)


# ─────────────────────────────────────────────────────────────────────────────
# Shared widget helpers
# ─────────────────────────────────────────────────────────────────────────────

def make_treeview(parent, columns: tuple, widths: tuple, height: int) -> ttk.Treeview:
    frame = ttk.Frame(parent)
    frame.pack(fill=tk.BOTH, expand=True)

    tree = ttk.Treeview(frame, columns=columns, show="headings", height=height)
    vsb  = ttk.Scrollbar(frame, orient=tk.VERTICAL, command=tree.yview)
    tree.configure(yscrollcommand=vsb.set)

    for col, width in zip(columns, widths):
        tree.heading(col, text=col)
        tree.column(col, width=width, anchor=tk.CENTER)

    tree.pack(side=tk.LEFT, fill=tk.BOTH, expand=True)
    vsb.pack(side=tk.RIGHT, fill=tk.Y)
    return tree


def fill_det_tree(tree: ttk.Treeview, detections: list) -> None:
    tree.delete(*tree.get_children())
    for d in detections:
        tree.insert("", tk.END, values=d)


def stamp_to_str(stamp) -> str:
    """Convert a ROS 2 builtin_interfaces/Time to a readable local-time string."""
    secs = stamp.sec + stamp.nanosec * 1e-9
    return datetime.fromtimestamp(secs, tz=timezone.utc) \
                   .astimezone()                          \
                   .strftime("%Y-%m-%d %H:%M:%S.%f")[:-3]


def msg_to_det_rows(msg: Detection2DArray) -> list:
    """Convert a Detection2DArray into a list of display rows for the det tree."""
    rows = []
    for det in msg.detections:
        class_id   = det.results[0].hypothesis.class_id if det.results else "—"
        confidence = det.results[0].hypothesis.score    if det.results else 0.0
        rows.append((
            class_id,
            f"{confidence:.4f}",
            f"{det.bbox.center.position.x:.2f}",
            f"{det.bbox.center.position.y:.2f}",
            f"{det.bbox.size_x:.1f}",
            f"{det.bbox.size_y:.1f}",
        ))
    return rows


# ─────────────────────────────────────────────────────────────────────────────
# Detail window
# ─────────────────────────────────────────────────────────────────────────────

class MessageDetailWindow(tk.Toplevel):
    """Floating window showing all detections for a selected log entry."""

    def __init__(self, parent):
        super().__init__(parent)
        self.title("Detection Detail")
        self.minsize(660, 300)

        self._tree = make_treeview(self, DET_COLS, DET_WIDTHS, height=12)

    def show(self, counter: int, msg_stamp: str, frame_id: str,
             det_rows: list) -> None:
        n = len(det_rows)
        self.title(
            f"Detection Detail  —  #{counter}  "
            f"frame={frame_id}  [{n} detection{'s' if n != 1 else ''}]"
        )
        fill_det_tree(self._tree, det_rows)
        self.lift()
        self.focus_force()


# ─────────────────────────────────────────────────────────────────────────────
# Main application window
# ─────────────────────────────────────────────────────────────────────────────

class App(tk.Tk):
    def __init__(self, msg_queue: queue.Queue, topic: str):
        super().__init__()
        self.title(f"Hailo Detector  —  {topic}")
        self.minsize(760, 560)

        self._queue      = msg_queue
        self._counter    = 0
        self._detail_win: MessageDetailWindow | None = None

        # log_store: iid → (counter, stamp_str, frame_id, det_rows)
        self._log_store: dict[str, tuple] = {}
        self._all_iids:  list[str]        = []   # newest-first, incl. detached

        self._build_status_bar(topic)
        self._build_latest_panel()
        self._build_log_panel()

        self.protocol("WM_DELETE_WINDOW", self._on_close)
        self._poll()

    # ── Construction ──────────────────────────────────────────────────────────

    def _build_status_bar(self, topic: str) -> None:
        bar = ttk.Frame(self, padding=(6, 4))
        bar.pack(fill=tk.X)

        ttk.Label(bar, text="Topic:").pack(side=tk.LEFT)
        ttk.Label(bar, text=topic,
                  foreground="steelblue").pack(side=tk.LEFT, padx=6)

        ttk.Separator(bar, orient=tk.VERTICAL).pack(
            side=tk.LEFT, fill=tk.Y, padx=8, pady=2)
        ttk.Label(bar, text="Status:").pack(side=tk.LEFT)
        self._status_var = tk.StringVar(value="Waiting for messages…")
        ttk.Label(bar, textvariable=self._status_var,
                  foreground="gray").pack(side=tk.LEFT, padx=4)

    def _build_latest_panel(self) -> None:
        latest = ttk.LabelFrame(self, text="Latest Message", padding=6)
        latest.pack(fill=tk.X, padx=8, pady=(4, 2))

        meta = ttk.Frame(latest)
        meta.pack(fill=tk.X, pady=(0, 4))

        self._num_var      = tk.StringVar(value="—")
        self._stamp_var    = tk.StringVar(value="—")
        self._frame_var    = tk.StringVar(value="—")
        self._det_count_var = tk.StringVar(value="—")

        for col, (label, var) in enumerate([
            ("#",          self._num_var),
            ("stamp",      self._stamp_var),
            ("frame_id",   self._frame_var),
            ("detections", self._det_count_var),
        ]):
            ttk.Label(meta, text=f"{label}:").grid(
                row=0, column=col * 2, sticky=tk.W,
                padx=(0 if col == 0 else 14, 2))
            ttk.Label(meta, textvariable=var, width=24 if label == "stamp" else 8
                      ).grid(row=0, column=col * 2 + 1, sticky=tk.W)

        self._det_tree = make_treeview(latest, DET_COLS, DET_WIDTHS, height=5)

    def _build_log_panel(self) -> None:
        log_frame = ttk.LabelFrame(self, text="Message Log", padding=6)
        log_frame.pack(fill=tk.BOTH, expand=True, padx=8, pady=(2, 8))

        self._log_tree = make_treeview(
            log_frame, LOG_COLS, LOG_WIDTHS, height=12)
        self._log_tree.bind("<<TreeviewSelect>>", self._on_log_select)

    # ── Queue polling ─────────────────────────────────────────────────────────

    def _poll(self) -> None:
        try:
            while True:
                msg = self._queue.get_nowait()
                self._handle_message(msg)
        except queue.Empty:
            pass
        self.after(POLL_MS, self._poll)

    def _handle_message(self, msg: Detection2DArray) -> None:
        self._counter += 1
        stamp_str  = stamp_to_str(msg.header.stamp)
        frame_id   = msg.header.frame_id or "—"
        det_rows   = msg_to_det_rows(msg)
        n          = len(det_rows)

        # Update status bar
        # self._status_var.configure(foreground="black")
        self._status_var.set(f"Last received: {stamp_str}")

        # Update latest panel
        self._num_var.set(str(self._counter))
        self._stamp_var.set(stamp_str)
        self._frame_var.set(frame_id)
        self._det_count_var.set(str(n))
        fill_det_tree(self._det_tree, det_rows)

        # Append to log
        iid = self._log_tree.insert(
            "", 0,
            values=(self._counter, stamp_str, frame_id, n),
        )
        self._log_store[iid] = (self._counter, stamp_str, frame_id, det_rows)
        self._all_iids.insert(0, iid)

        # Prune oldest beyond cap
        while len(self._all_iids) > MAX_LOG_ROWS:
            old = self._all_iids.pop()
            self._log_store.pop(old, None)
            if self._log_tree.exists(old):
                self._log_tree.delete(old)

    # ── Log selection → detail window ─────────────────────────────────────────

    def _on_log_select(self, _event) -> None:
        sel = self._log_tree.selection()
        if not sel:
            return
        iid = sel[0]
        stored = self._log_store.get(iid)
        if stored is None:
            return
        counter, stamp_str, frame_id, det_rows = stored

        if not (self._detail_win and self._detail_win.winfo_exists()):
            self._detail_win = MessageDetailWindow(self)
        self._detail_win.show(counter, stamp_str, frame_id, det_rows)

    # ── Clean shutdown ────────────────────────────────────────────────────────

    def _on_close(self) -> None:
        rclpy.shutdown()
        self.destroy()


# ─────────────────────────────────────────────────────────────────────────────
# Entry point
# ─────────────────────────────────────────────────────────────────────────────

def main():
    rclpy.init()

    # Read the topic parameter before handing control to Tkinter
    tmp = rclpy.create_node("_param_reader")
    tmp.declare_parameter("topic", "detections")
    topic = tmp.get_parameter("topic").get_parameter_value().string_value
    tmp.destroy_node()

    msg_queue = queue.Queue()
    ros_node  = DetectionSubscriber(msg_queue, topic)

    # Spin the ROS 2 node in a background thread
    spin_thread = threading.Thread(
        target=rclpy.spin, args=(ros_node,), daemon=True)
    spin_thread.start()

    app = App(msg_queue, topic)
    app.mainloop()

    # Tkinter has exited — make sure ROS 2 is cleaned up
    rclpy.shutdown()
    spin_thread.join(timeout=2.0)


if __name__ == "__main__":
    main()
